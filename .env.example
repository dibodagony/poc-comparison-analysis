# ─── POC Comparison Dashboard — Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in your values.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# n8n Webhook URL
# Find this in your n8n Webhook Trigger node → "Test URL" or "Production URL"
VITE_WEBHOOK_URL=https://YOUR_N8N_INSTANCE/webhook/poc-comparison

# n8n Webhook API key
# In n8n: Webhook node → Authentication → Header Auth
#   Header Name:  Authorization
#   Header Value: Bearer <your-key>
# Paste only the key part here (without "Bearer "):
VITE_WEBHOOK_API_KEY=your-secret-key-here

# Mock mode — set to "false" to send real requests to n8n
# Set to "true" during frontend development to skip the real webhook
VITE_USE_MOCK=false
